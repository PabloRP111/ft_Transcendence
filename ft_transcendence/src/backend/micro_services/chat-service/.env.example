PORT=3003

# Production / full-stack (root docker-compose.yml):
#   Uses the shared postgres container. "postgres" resolves via Docker's internal DNS.
DATABASE_URL=postgresql://transcendence:transcendence@postgres:5432/chat_db

# Local development only (chat-service/docker-compose.yml standalone):
#   Uncomment the line below and comment out the one above.
# DATABASE_URL=postgresql://chat_user:chat_pass@localhost:5433/chat_db

JWT_SECRET=your-jwt-secret-here
